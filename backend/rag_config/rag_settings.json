{
  "RAG_설정": {
    "시스템명": "신용카드 분석 RAG LLM",
    "버전": "2.0",
    "설명": "신용카드 추천 시스템용 RAG (Retrieval-Augmented Generation) LLM 설정",
    "마지막_업데이트": "2026-04-10"
  },

  "청킹설정": {
    "전략": "계층적 청킹",
    "설명": "마크다운 섹션 기반 구조화된 청킹",
    "min_token": 100,
    "max_token": 1000,
    "overlap_ratio": 0.1,
    "섹션우선순위": {
      "메타데이터": 1,
      "기본정보": 2,
      "연회비": 3,
      "혜택": 3,
      "손익분석": 4,
      "타겟고객": 4,
      "특성": 5,
      "비교": 5
    }
  },

  "임베딩설정": {
    "모델": "text-embedding-3-small",
    "제공자": "OpenAI",
    "차원": 1536,
    "배치크기": 100,
    "인코딩": "utf-8",
    "정규화": true
  },

  "검색설정": {
    "유형": "유사도 검색",
    "상위K": 3,
    "유사도_임계값": 0.35,
    "재순위지정": true,
    "필터링": {
      "카드사": true,
      "등급": true,
      "타겟고객": true
    }
  },

  "키워드설정": {
    "키워드": [
      "연회비",
      "마일리지",
      "라운지",
      "해외거래",
      "손익분석",
      "가족카드",
      "포인트",
      "캐시백",
      "할인",
      "국제브랜드",
      "제휴사",
      "보험혜택"
    ],
    "제외단어": [
      "그리고",
      "또는",
      "있습니다",
      "경우",
      "적용"
    ],
    "최소_빈도": 2
  },

  "재순위지정": {
    "활성화": true,
    "모델": "cross-encoder",
    "배치크기": 32,
    "상위K": 10
  },

  "캐싱": {
    "활성화": true,
    "TTL_초": 3600,
    "최대_항목": 10000
  },

  "성능": {
    "병렬처리": true,
    "최대_스레드": 4,
    "타임아웃_초": 30,
    "재시도": 3,
    "재시도_딜레이_초": 1
  },

  "로깅": {
    "수준": "INFO",
    "파일": "logs/rag_system.log",
    "회전": "daily"
  },

  "데이터_소스": {
    "마크다운": {
      "경로": "analysis/",
      "확장자": ".md",
      "인코딩": "utf-8",
      "동기화": true
    },
    "JSON": {
      "경로": "data/",
      "확장자": ".json",
      "검증": true
    }
  }
